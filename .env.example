# ── Imagens (GHCR — build no GitHub Actions, VPS só faz pull) ─
FRONTEND_IMAGE=ghcr.io/giovanniguariento/citypenha-frontend:latest
BACKEND_IMAGE=ghcr.io/giovanniguariento/citypenha-backend:latest

# ── Domínio público ──────────────────────────────────────────
PUBLIC_DOMAIN=citypenha.com.br
# API_URL: usado no CI do repo cityPenha (build-arg), não no compose em runtime
API_URL=https://citypenha.com.br/api/

# ── Backend ──────────────────────────────────────────────────
NODE_ENV=production
TZ=America/Sao_Paulo
PORT=3000

# Banco (mesmo schema WordPress)
DATABASE_HOST=mariadb
DATABASE_PORT=3306
DATABASE_USER=wordpress
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_NAME=wordpress
DATABASE_URL=mysql://wordpress:CHANGE_ME_STRONG_PASSWORD@mariadb:3306/wordpress
DATABASE_POOL_SIZE=5
DATABASE_CONNECT_TIMEOUT=10000

# WordPress REST (rede interna Docker)
ENV_API_WORDPRESS=http://wordpress-nginx:8080/wp-json/wp/v2
ENV_API_WORDPRESS_ADMIN_USER=admin
ENV_API_WORDPRESS_ADMIN_PASSWORD=CHANGE_ME_WP_APP_PASSWORD

# Firebase Admin (escolher UMA opção)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase.json

# Admin (UIDs Firebase separados por vírgula)
ADMIN_FIREBASE_UIDS=uid1,uid2

# Discovery (opcionais)
DISCOVERY_WORLD_NEWS_CATEGORY_IDS=3,7,12
DISCOVERY_LIMIT_WORLD_NEWS=10
DISCOVERY_LIMIT_TRENDING=10
DISCOVERY_LIMIT_POPULAR_AUTHORS=10

# Ads (opcionais)
AD_INTERVAL_MIN=4
AD_INTERVAL_MAX=5

# Logging (opcionais)
LOG_LEVEL=warn
LOG_SLOW_MS=3000

# ── WordPress ────────────────────────────────────────────────
# URL pública do WP (com prefixo /blog). Usada por WP_HOME/WP_SITEURL no container.
# Vazio no restore → https://PUBLIC_DOMAIN/blog
WORDPRESS_PUBLIC_URL=http://localhost/blog
WORDPRESS_DB_HOST=mariadb:3306
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
WORDPRESS_DB_NAME=wordpress

# ── MariaDB ──────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD
